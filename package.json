{
  "name": "gpa-ng-workspace",
  "version": "0.0.1 ",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:lib": "ng build ng-core-ui --configuration production && bun run build:schematics",
    "build:schematics": "tsc -p projects/ng-core-ui/schematics/tsconfig.json"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": false,
  "devDependencies": {
    "@angular-devkit/core": "^21.2.1",
    "@angular-devkit/schematics": "^21.2.1",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.1",
    "@schematics/angular": "^21.2.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.0.0",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^21.1.0",
    "typescript": "~5.9.3"
  },
  "peerDependencies": {
    "@angular/common": "^21.2.1",
    "@angular/router": "^21.2.1",
    "@angular/core": "^21.2.1",
    "@angular/material": "^21.2.1",
    "@tailwindcss/postcss": "^4.2.1"
  }

}
