{
  "name": "gpa-ng-workspace",
  "version": "0.0.1 ",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:lib": "node -e \"require('fs').copyFileSync('README.md','projects/ng-core-ui/README.md')\" && node scripts/build-components-css.mjs && node scripts/build-bin.mjs && ng build ng-core-ui --configuration production && tsc -p projects/ng-core-ui/schematics/tsconfig.json && node -e \"const fs=require('fs'),f='dist/ng-core-ui/package.json',p=JSON.parse(fs.readFileSync(f,'utf8'));delete p.type;fs.writeFileSync(f,JSON.stringify(p,null,2)+'\\n');console.log('Removed type:module from dist package.json');\"",
    "build:components-css": "node scripts/build-components-css.mjs",
    "build:schematics": "tsc -p projects/ng-core-ui/schematics/tsconfig.json"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": false,
  "devDependencies": {
    "@angular-devkit/core": "^22.0.1",
    "@angular-devkit/schematics": "^22.0.1",
    "@angular/build": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@schematics/angular": "^22.0.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^22.0.0",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "^22.0.0",
    "typescript": "~6.0.3"
  },
  "peerDependencies": {
    "@angular/common": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/material": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@tailwindcss/postcss": "^4.2.1"
  }
}
